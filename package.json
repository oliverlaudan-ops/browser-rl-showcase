{
  "name": "browser-rl-showcase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based DQN/PPO training showcase with TensorFlow.js — loss curves, live agent visualization, and environment comparison",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.20.0",
    "chart.js": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/chart.js": "^2.9.41",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
